#!/bin/bash
# Automated Restic backup script
# Generated by Ansible

LOG_FILE="/var/log/restic_backup_$(date +%Y-%m-%d).log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

log "=== Starting Restic Backup ==="

if [ -f "/opt/backups/restic.env" ]; then
    source /opt/backups/restic.env
else
    log "ERROR: /opt/backups/restic.env not found. Aborting."
    exit 1
fi

{% for path in restic_backup_paths %}
TAG_NAME=$(basename "{{ path }}")

log "Starting backup for {{ path }} (Tag: $TAG_NAME)..."
if restic backup --tag "$TAG_NAME" "{{ path }}" >> "$LOG_FILE" 2>&1; then
    log "Backup for {{ path }} was successful."
else
    log "ERROR: Backup for {{ path }} failed."
fi
{% endfor %}

log "Starting restic cleanup (forget & prune)..."
if restic forget --prune --keep-daily 7 --keep-weekly 4 --keep-monthly 6 >> "$LOG_FILE" 2>&1; then
    log "Cleanup was successful."
else
    log "ERROR: Cleanup failed."
fi

log "=== Backup Process Completed ==="
exit 0
