#!/bin/bash
# Automated SnapRAID scrub script
# Generated by Ansible

LOG_FILE="/var/log/snapraid_scrub_$(date +%Y-%m-%d).log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

log "=== Starting SnapRAID Scrub ==="

if snapraid scrub >> "$LOG_FILE" 2>&1; then
    log "SnapRAID scrub completed successfully."
    exit 0
else
    log "ERROR: SnapRAID scrub failed. Check logs."
    exit 1
fi
