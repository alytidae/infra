#!/bin/bash
# Automated SnapRAID sync script
# Generated by Ansible

LOG_FILE="/var/log/snapraid_sync_$(date +%Y-%m-%d).log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

log "=== Starting SnapRAID Sync ==="

if snapraid sync >> "$LOG_FILE" 2>&1; then
    log "SnapRAID sync completed successfully."
    exit 0
else
    log "ERROR: SnapRAID sync failed. Check logs."
    exit 1
fi
